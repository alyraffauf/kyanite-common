[Unit]
Description=Ollama (containerized, CPU)
After=network-online.target
Wants=network-online.target
Conflicts=ollama-rocm.service ollama-vulkan.service

[Container]
Image=docker.io/ollama/ollama:latest
ContainerName=ollama
AutoUpdate=registry
Network=ai
NetworkAlias=ollama
PublishPort=127.0.0.1:11434:11434
Volume=ollama-data:/root/.ollama

[Service]
Restart=on-failure
TimeoutStartSec=900

[Install]
WantedBy=default.target
